# ────────────────────────────────────────────────────────────
# TeleVault Environment Variables
# Copy to .env and fill in your values
# ────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Generate session string: pip install telethon && python -c "from telethon.sync import TelegramClient; from telethon.sessions import StringSession; c=TelegramClient(StringSession(),'YOUR_API_ID','YOUR_API_HASH'); c.start(); print(c.session.save())"
TELEGRAM_SESSION_STRING=

# Channel ID for your private storage channel.
# Use the FULL ID from web.telegram.org URL, e.g. -1001234567890
# If you only have -4431122916, use -1004431122916 instead. (add -100 in front)
TELEGRAM_CHANNEL_ID=

# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_to_strong_password

# Full URL (auto-set in docker-compose, override for local dev)
DATABASE_URL=postgresql+asyncpg://televault:change_me_to_strong_password@localhost:5432/televault

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_to_strong_password

REDIS_URL=redis://:change_me_to_strong_password@localhost:6379/0

# ── App Security ─────────────────────────────────────────────
SECRET_KEY=generate_with_openssl_rand_hex_32

# ── Optional ─────────────────────────────────────────────────
DEBUG=false
JWT_EXPIRE_SECONDS=3600

# Temp directory for chunk processing (mount as tmpfs for performance)
TEMP_DIR=/tmp/televault

# ── Vault ────────────────────────────────────────────────────
# Master password for unlocking the vault
# Set this to a very strong password. If you lose this, your files are unrecoverable!
MASTER_PASSWORD=change_me_to_strong_master_password
